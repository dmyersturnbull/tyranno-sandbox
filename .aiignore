# https://www.jetbrains.com/help/junie/aiignore.html
# Slowly becoming a standard.

# Paths starting or ending in `~`, `$`, or `#`; or starting in `.~`.
# These are normally temp files like `~$doc.docx` or `.profile#`.
*[~#$]
[~#$]*
.~*

# Temp and misc. unwanted files
*[.~]bak
*[.~]out
*[.~]swp
*[.~]temp
*[.~]tmp
*.log
*.pid
Thumbs.db

# IDE directories
.idea/
.vscode/

# Build directories
/bin/
/build/
/dist/
/obj/
/out/
/sdist/
/target/
.next/
.nuxt/

# Cache dirs
.cache/
.*-cache/
.esbuild/
.vite/
.turbo/
.nx/

# Auto-generated docs
/docs/html/
/docs/_build/
/docs/autoapi/
/site/

# Python
__pycache__/
__pypackages__/
cython_debug/
*.py[cod]
.venv/

# JavaScript
node_modules/
.npm/
.build/
.eslintcache
*.tsbuildinfo

# Bundled assets
*.map
*.min.js
*.min.css

# Private
.*.env
*.pem
